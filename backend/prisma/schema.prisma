// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studentProfile   StudentProfile?
  teacherProfile   TeacherProfile?
  adminProfile     AdminProfile?
  loginHistory     LoginHistory[]
  notifications    Notification[]
  quizSessions     QuizSession[]
  materialViews    MaterialView[]

  @@index([email])
  @@index([role])
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

model StudentProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  grade             Int
  school            String
  learningStyle     String? // visual, auditory, kinesthetic
  strengths         String[]
  weaknesses        String[]
  riskScore         Float    @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  classStudents     ClassStudent[]
  learningPaths     LearningPath[]
  riskScores        StudentRiskScore[]

  @@index([userId])
}

model TeacherProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  subject   String
  classes   Class[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AdminProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Class {
  id              String   @id @default(cuid())
  name            String
  description     String?
  teacherId       String
  grade           Int
  subject         String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  teacher         TeacherProfile @relation(fields: [teacherId], references: [id])
  students        ClassStudent[]
  questions       Question[]
  materials       Material[]
  learningPaths   LearningPath[]

  @@index([teacherId])
  @@index([grade])
}

model ClassStudent {
  id        String   @id @default(cuid())
  classId   String
  studentId String
  enrolledAt DateTime @default(now())

  class     Class          @relation(fields: [classId], references: [id], onDelete: Cascade)
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classId, studentId])
  @@index([classId])
  @@index([studentId])
}

model Question {
  id              String   @id @default(cuid())
  classId         String
  text            String   @db.Text
  type            QuestionType
  difficulty      Int      @default(1)
  options         String[] // JSON stringified options
  correctAnswer   String
  explanation     String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  class           Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  quizAnswers     QuizAnswer[]
  errorAnalysis   QuizErrorAnalysis[]

  @@index([classId])
  @@index([difficulty])
}

enum QuestionType {
  MULTIPLE_CHOICE
  SHORT_ANSWER
  TRUE_FALSE
  ESSAY
}

model QuizSession {
  id          String   @id @default(cuid())
  studentId   String
  classId     String
  startedAt   DateTime @default(now())
  endedAt     DateTime?
  score       Float?
  totalQuestions Int
  correctAnswers Int @default(0)
  status      SessionStatus @default(IN_PROGRESS)

  student     User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  answers     QuizAnswer[]

  @@index([studentId])
  @@index([status])
  @@index([startedAt])
}

enum SessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

model QuizAnswer {
  id        String   @id @default(cuid())
  sessionId String
  questionId String
  answer    String
  isCorrect Boolean
  timeSpent Int      // in seconds
  createdAt DateTime @default(now())

  session   QuizSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question  Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([questionId])
}

model Material {
  id              String   @id @default(cuid())
  classId         String
  title           String
  description     String?  @db.Text
  content         String   @db.Text
  type            MaterialType
  url             String?
  aiGenerated     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  class           Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  views           MaterialView[]
  aiMaterial      AiGeneratedMaterial?

  @@index([classId])
  @@index([aiGenerated])
}

enum MaterialType {
  PDF
  VIDEO
  ARTICLE
  INTERACTIVE
  EXERCISE
}

model MaterialView {
  id        String   @id @default(cuid())
  materialId String
  userId    String
  viewedAt  DateTime @default(now())
  timeSpent Int      // in seconds

  material  Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([materialId, userId])
  @@index([materialId])
  @@index([userId])
}

model AiGeneratedMaterial {
  id          String   @id @default(cuid())
  materialId  String   @unique
  prompt      String   @db.Text
  model       String
  generatedAt DateTime @default(now())

  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@index([materialId])
}

model StudentRiskScore {
  id        String   @id @default(cuid())
  studentId String
  classId   String?
  score     Float
  reason    String   @db.Text
  assessedAt DateTime @default(now())

  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([score])
}

model LearningPath {
  id          String   @id @default(cuid())
  studentId   String
  classId     String
  title       String
  description String? @db.Text
  status      PathStatus @default(ACTIVE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  student     StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class       Class          @relation(fields: [classId], references: [id], onDelete: Cascade)
  items       LearningPathItem[]

  @@index([studentId])
  @@index([classId])
}

enum PathStatus {
  ACTIVE
  COMPLETED
  PAUSED
}

model LearningPathItem {
  id          String   @id @default(cuid())
  pathId      String
  materialId  String?
  order       Int
  completed   Boolean  @default(false)
  completedAt DateTime?

  path       LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)

  @@index([pathId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String   @db.Text
  type      NotificationType
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
}

enum NotificationType {
  ACHIEVEMENT
  QUIZ_RESULT
  NEW_MATERIAL
  RISK_ALERT
  SYSTEM
}

model LoginHistory {
  id        String   @id @default(cuid())
  userId    String
  loginAt   DateTime @default(now())
  ip        String?
  userAgent String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model QuizErrorAnalysis {
  id        String   @id @default(cuid())
  questionId String
  studentId String
  errorType String   // concept, calculation, misread, etc
  frequency Int      @default(1)
  suggestion String? @db.Text
  updatedAt DateTime @updatedAt

  question  Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, studentId, errorType])
  @@index([questionId])
}
