generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  passwordUpdatedAt DateTime?

  notifications AdminNotification[]

  @@index([email])
}

model Teacher {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String
  name          String
  nip           String?  @unique
  subjectTaught String?
  school        String?
  phone         String?
  position      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  passwordUpdatedAt DateTime?

  classes       Class[]
  notifications TeacherNotification[]

  @@index([email])
}

model Student {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String
  name          String
  nisn          String?  @unique
  grade         Int
  className     String?  // Contoh: 10A
  school        String?  // Contoh: SMA Negeri 1 Jakarta
  dateOfBirth   DateTime?
  address       String?
  parentName    String?
  parentPhone   String?
  learningStyle String? // visual, auditory, kinesthetic
  riskScore     Float    @default(0)
  avatar        String?
  darkModeEnabled Boolean @default(false)
  hapticEnabled Boolean @default(true)
  notificationsEnabled Boolean @default(true)
  passwordUpdatedAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  classStudents  ClassStudent[]
  quizSessions   QuizSession[]
  learningPaths  LearningPath[]
  notifications  StudentNotification[]
  loginHistories LoginHistory[]
  riskScores     StudentRiskScore[]
  materialViews  MaterialView[]

  @@index([email])
}

model Class {
  id            String         @id @default(cuid())
  name          String
  code          String         @unique @default(cuid())
  description   String?
  teacherId     String
  grade         Int
  subject       String?
  archived      Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  teacher       Teacher        @relation(fields: [teacherId], references: [id])
  students      ClassStudent[]
  questions     Question[]
  materials     Material[]
  assignments   Assignment[]
  quizzes       Quiz[]
  learningPaths LearningPath[]

  @@index([teacherId])
  @@index([grade])
  @@index([code])
}

model ClassStudent {
  id         String   @id @default(cuid())
  classId    String
  studentId  String
  enrolledAt DateTime @default(now())

  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classId, studentId])
  @@index([classId])
  @@index([studentId])
}

model Question {
  id            String              @id @default(cuid())
  classId       String
  text          String              @db.Text
  type          QuestionType
  difficulty    Int                 @default(1)
  topic         String?             @default("Umum")
  subTopic      String?
  options       String[] // JSON stringified options
  correctAnswer String
  explanation   String?             @db.Text
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  class         Class               @relation(fields: [classId], references: [id], onDelete: Cascade)
  quizAnswers   QuizAnswer[]
  errorAnalysis QuizErrorAnalysis[]

  @@index([classId])
  @@index([difficulty])
  @@index([topic])
}

enum QuestionType {
  MULTIPLE_CHOICE
  SHORT_ANSWER
  TRUE_FALSE
  ESSAY
}

model QuizSession {
  id             String        @id @default(cuid())
  studentId      String
  classId        String
  quizId         String?
  startedAt      DateTime      @default(now())
  endedAt        DateTime?
  score          Float?
  totalQuestions Int
  correctAnswers Int           @default(0)
  status         SessionStatus @default(IN_PROGRESS)

  student Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  quiz    Quiz?        @relation(fields: [quizId], references: [id], onDelete: SetNull)
  answers QuizAnswer[]

  @@index([studentId])
  @@index([status])
  @@index([startedAt])
  @@index([quizId])
}

enum SessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

model QuizAnswer {
  id         String   @id @default(cuid())
  sessionId  String
  questionId String
  answer     String
  isCorrect  Boolean
  timeSpent  Int // in seconds
  createdAt  DateTime @default(now())

  quizSession QuizSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question    Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([questionId])
}

model Material {
  id          String                @id @default(cuid())
  classId     String
  title       String
  description String?               @db.Text
  content     String                @db.Text
  extractedText String?             @db.Text
  type        MaterialType
  url         String?
  aiGenerated Boolean               @default(false)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  class       Class                 @relation(fields: [classId], references: [id], onDelete: Cascade)
  views       MaterialView[]
  aiMaterial  AiGeneratedMaterial?

  @@index([classId])
  @@index([aiGenerated])
}

enum MaterialType {
  PDF
  VIDEO
  ARTICLE
  INTERACTIVE
  EXERCISE
}

model MaterialView {
  id         String   @id @default(cuid())
  materialId String
  studentId  String
  viewedAt   DateTime @default(now())
  timeSpent  Int // in seconds

  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  student  Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([materialId, studentId])
  @@index([materialId])
  @@index([studentId])
}

model AiGeneratedMaterial {
  id          String   @id @default(cuid())
  materialId  String   @unique
  prompt      String   @db.Text
  model       String
  generatedAt DateTime @default(now())

  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@index([materialId])
}

model StudentRiskScore {
  id           String   @id @default(cuid())
  studentId    String
  classId      String?
  riskScore    Float
  riskCategory String   @default("NORMAL")
  reason       String   @db.Text
  date         DateTime @default(now())
  assessedAt   DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@index([studentId])
  @@index([riskScore])
}

model LearningPath {
  id          String             @id @default(cuid())
  studentId   String
  classId     String
  title       String
  subject     String?            @default("Umum")
  description String?            @db.Text
  weakTopics  String?            @db.Text
  status      PathStatus         @default(ACTIVE)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  student     Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class       Class              @relation(fields: [classId], references: [id], onDelete: Cascade)
  items       LearningPathItem[]

  @@index([studentId])
  @@index([classId])
}

enum PathStatus {
  ACTIVE
  COMPLETED
  PAUSED
}

model LearningPathItem {
  id             String    @id @default(cuid())
  learningPathId String
  materialId     String?
  topic          String?
  order          Int
  orderIndex     Int       @default(0)
  completed      Boolean   @default(false)
  completedAt    DateTime?
  status         String    @default("TODO")
  masterScore    Float?

  path LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)

  @@index([learningPathId])
}

model StudentNotification {
  id        String           @id @default(cuid())
  studentId String
  title     String
  message   String           @db.Text
  type      NotificationType
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([read])
}

model TeacherNotification {
  id        String           @id @default(cuid())
  teacherId String
  title     String
  message   String           @db.Text
  type      NotificationType
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([read])
}

model AdminNotification {
  id        String           @id @default(cuid())
  adminId   String
  title     String
  message   String           @db.Text
  type      NotificationType
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  admin Admin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([read])
}

enum NotificationType {
  ACHIEVEMENT
  QUIZ_RESULT
  NEW_MATERIAL
  RISK_ALERT
  SYSTEM
}

model LoginHistory {
  id         String   @id @default(cuid())
  studentId  String
  loggedInAt DateTime @default(now())
  ip         String?
  userAgent  String?

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

model QuizErrorAnalysis {
  id            String   @id @default(cuid())
  questionId    String
  studentId     String
  errorType     String // concept, calculation, misread, etc
  weakSubTopics String   @default("[]") // JSON stringified
  frequency     Int      @default(1)
  suggestion    String?  @db.Text
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, studentId, errorType])
  @@index([questionId])
}
model Quiz {
  id             String         @id @default(cuid())
  classId        String
  title          String
  timeLimit      Int            @default(15)
  questionsCount Int            @default(0)
  shuffle        Boolean        @default(true)
  showResult     Boolean        @default(true)
  autoGrade      Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  class          Class          @relation(fields: [classId], references: [id], onDelete: Cascade)
  questions      QuizQuestion[]
  sessions       QuizSession[]

  @@index([classId])
}

model QuizQuestion {
  id            String   @id @default(cuid())
  quizId        String
  text          String   @db.Text
  type          String   @default("MULTIPLE_CHOICE")
  options       String   @db.Text // JSON stringified
  correctAnswer String
  explanation   String?  @db.Text
  
  quiz          Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
}

model Assignment {
  id          String   @id @default(cuid())
  classId     String
  title       String
  description String   @db.Text
  deadline    DateTime
  points      Int      @default(100)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@index([classId])
}
