{
  "name": "edubridge-backend",
  "version": "1.0.0",
  "description": "EduBridge AI adaptive learning platform backend",
  "main": "dist/index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "dev": "nodemon --exec \"ts-node -r dotenv/config src/index.ts\"",
    "build": "tsc",
    "start": "node dist/index.js",
    "postinstall": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:pull": "prisma db pull",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^5.22.0",
    "axios": "^1.16.1",
    "bcrypt": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "groq-sdk": "^1.2.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.10",
    "pdf-parse": "^2.4.5",
    "uploadthing": "^7.7.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^20.3.1",
    "@types/nodemailer": "^8.0.0",
    "@types/pdf-parse": "^1.1.5",
    "nodemon": "^3.0.1",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.3"
  }
}
